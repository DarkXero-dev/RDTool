{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RDTool",
  "version": "0.1.0",
  "identifier": "com.techxero.rdtool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RDTool",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzMDlCQTJGNEREMEJCOEEKUldTS3U5Qk5MN29KWS93bjk2K1ZwWWg5ZVAzOGNSdjN6Rmd3aWt6T3ZlajRjR0J0b2FaTXJXbWYK",
      "endpoints": [
        "https://github.com/DarkXero-dev/RDTool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
